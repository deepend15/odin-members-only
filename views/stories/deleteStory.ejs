<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/styles.css" />
    <title><%= title %> | AnonTales</title>
  </head>
  <body>
    <%- include('../partials/nav') %>
    <div class="container">
      <% if (!locals.currentUser || (locals.currentUser && !(locals.currentUser.username === story.username || locals.currentUser.admin))) { %>
        <%- include('../partials/noAccess') %>
      <% } else { %>
        <div class="delete-story-div">
          <h1><%= title %> 🗑️</h1>
          <form class="delete-story-form" action="/stories/view-story/<%= story.story_id %>/delete" method="POST">
            <p>❗ Are you sure you want to delete this story?</p>
            <button>Delete story</button>
          </form>
          <a href="/stories/view-story/<%= story.story_id %>">&lt;&lt; Cancel</a>
          <p><%= story.title %></p>
          <pre><%= story.story %></pre>
        </div>
      <% } %>
    </div>
    <%- include('../partials/footer') %>
  </body>
</html>
