<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/styles.css" />
    <title><%= title %> | AnonTales</title>
  </head>
  <body>
    <%- include('../partials/nav') %>
    <div class="container">
      <div class="create-story-div">
        <h1><%= title %></h1>
        <% if (!locals.currentUser) { %>
          <%- include('../partials/noAccess') %>
        <% } else { %>
          <p>Submit your story below!</p>
          <p class="warning-div">Be aware! anonClub members will be able to see that your username created this story, and the date that you created it. No other details of your account will be shared with anonClub members, and no other visitors to this site will be able to see this information. For more information, visit the anonClub <a href="/join-the-club">info page</a>.</p>
          <% } %>        
          <a href="/stories">&lt;&lt; Story depository</a>
      </div>
    </div>
  </body>
</html>
