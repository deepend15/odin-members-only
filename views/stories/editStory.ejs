<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/styles.css" />
    <title><%= title %> | AnonTales</title>
  </head>
  <body>
    <%- include('../partials/nav') %>
    <div class="container">
      <% if (!locals.currentUser || (locals.currentUser && !(locals.currentUser.username === story.username))) { %>
        <%- include('../partials/noAccess') %>
      <% } else { %>
        <div class="edit-story-div">
          <h1><%= title %> 📝</h1>
          <%- include('../partials/errors') %>
          <form class="edit-story-form" action="/stories/view-story/<%= story.story_id %>/edit" method="POST">
            <p>
              <label for="title">Title:</label>
              <input
                type="text"
                name="title"
                id="title"
                maxlength="75"
                value="<%= (locals.submittedTitle) ? submittedTitle : story.title %>"
                autofocus
                required
              >
            </p>
            <textarea name="story" id="story" rows="10" required><%= (locals.submittedStory) ? submittedStory : story.story %></textarea>
            <button>Submit changes</button>
          </form>
          <a href="/stories/view-story/<%= story.story_id %>">&lt;&lt; Cancel</a>
        </div>
    <% } %>
    </div>
    <%- include('../partials/footer') %>
  </body>
</html>
