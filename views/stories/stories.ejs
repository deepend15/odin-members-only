<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/styles.css" />
    <title><%= title %> | AnonTales</title>
  </head>
  <body>
    <%- include('../partials/nav') %>
    <div class="container">
      <div class="stories-div">
        <h1><%= title %></h1>
        <% if (locals.currentUser) { %>
          <h2><%= h2Content %></h2>
          <div class="story-buttons-div">
            <% if (locals.currentUserStories) { %>
              <a href="/stories"><button>All stories</button></a>
            <% } else { %>
              <a href="/stories?currentUser=true %>"><button>My stories</button></a>
            <% } %>
            <a href="/stories/create-story"><button>Create new story</button></a>
          </div>
          <% if (!currentUser.member && !locals.currentUserStories) { %>
            <p>&#128064; tip: If you want to see who created each story, <a href="/join-the-club">join the anonClub</a>!</p>
          <% } %>
        <% } else { %>
          <p>Want to create and share your own stories? <a href="/sign-up">Sign up</a> or <a href="/log-in">log in</a>!</p>
        <% } %>
        <div class="stories-container">
          <% if (stories.length > 0) { %>
            <% stories.forEach((story) => { %>
              <a href="/stories/view-story?id=<%= story.story_id %>">
                <button class="indiv-story-btn">
                  <div class="h3-div">
                    <h3><%= story.title %></h3>
                    <span><%= story.title %></span>
                  </div>
                  <pre><%= story.story %></pre>
                  <!-- <div class="secret-line">
                    <p><%= story.username %></p>
                    <p><%= story.time %></p>
                  </div> -->
                  <% if (locals.currentUser) { %>
                    <% if (locals.currentUser.member) { %>
                      <div class="secret-line">
                      <p><%= story.username %></p>
                      <p><%= story.time %></p>
                    </div>
                    <% } %>
                  <% } %>
                  </button>
              </a>
            <% }); %>
          <% } %>
        </div>
      </div>
    </div>
  </body>
</html>
