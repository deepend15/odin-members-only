<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/styles.css" />
    <title><%= title %> | AnonTales</title>
  </head>
  <body>
    <%- include('../partials/nav') %>
    <div class="container">
      <% if (!locals.currentUser) { %>
        <%- include('../partials/noAccess') %>
      <% } else { %>
        <div class="edit-account-div">
          <h1><%= title %> ✏️</h1>
          <p>What do you want to update?</p>
          <a href="/my-account/edit/name-username"><button>account name and/or username</button></a>
          <a href="/my-account/edit/password"><button>account password</button></a>
          <a href="/my-account">&lt;&lt; My account</a>
        </div>
      <% } %>
    </div>
    <%- include('../partials/footer') %>
  </body>
</html>
